    background-color: #a2cbff; /* Nền trong suốt */
	background-color: rgb(162, 203, 255);
    color: #ffffff;                /* Chữ trắng */
    border: 1px solid #444444;     /* Viền xám mờ */
    border-radius: 12px;           /* Bo góc hiện đại, không quá tròn */
    font-family: &quot;Segoe UI&quot;;
    font-size: 16px;
    padding: 10px;
}

QPushButton:hover {
    border: 1px solid #00f2ff;     /* Viền sáng xanh khi di chuột */
    color: #00f2ff;                /* Chữ sáng xanh */
    background-color: rgba(0, 242, 255, 0.05); /* Nền hơi xanh cực nhẹ */
}

QPushButton:pressed {
    background-color: rgba(0, 242, 255, 0.2);
}</string>
