      <pointsize>-1</pointsize>
      <weight>75</weight>
      <bold>true</bold>
     </font>
    </property>
    <property name="styleSheet">
     <string notr="true">QPushButton {
    /* Màu nền trong suốt */
    background-color: transparent;
    color: #00796B; /* Màu chữ chính (Ví dụ: Xanh ngọc) */
    
    /* Font chữ */
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 24px;
    font-weight: bold;
    
    /* Viền nút */
    border: 2px solid #00796B; /* Viền mỏng */
    border-radius: 12px;
    
    /* Kích thước */
    min-width: 60px;
    min-height: 60px;
}

/* HIỆU ỨNG: Khi chạm vào (Pressed) - Nút sẽ lấp đầy màu */
QPushButton:pressed {
    background-color: #00796B; /* Tô màu nền */
    color: #FFFFFF; /* Đổi chữ thành trắng */
}

/* HIỆU ỨNG: Khi nút đang ở trạng thái được chọn (Selected/Checked) */
/* Cần set setCheckable(True) cho nút trong Python */
QPushButton:checked {
    background-color: #004D40; /* Màu tối hơn */
    color: #FFFFFF;
    border: 2px solid #004D40;
}</string>
    </property>
    <property name="text">
     <string>1</string>
    </property>
   </widget>
